// /prisma/schema.prisma

// ... your existing generator and datasource blocks ...

model Order {
  id           String   @id @default(cuid())
  // ... your existing fields (productId, amount, etc.) ...
  
  // New fields required for the missing checkout flow
  customerName String?
  phone        String?
  city         String?
  address      String?
  
  createdAt    DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  type        String
  value       Float
  imageUrl    String?  // Ensure this exists to save the uploaded image link
}