generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  type      String
  value     Float
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Order {
  id           String   @id @default(cuid())
  productName  String
  amount       Float
  status       String   @default("pending")
  
  // Missing Fields Added:
  customerName String?
  phone        String?
  city         String?
  address      String?
  
  createdAt    DateTime @default(now())
}