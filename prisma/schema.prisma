generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String
  price       Float
  imageUrl    String   @default("[Image]")
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String   @id @default(cuid())
  totalAmount   Float
  items         String   
  status        String   @default("PENDING_VERIFICATION")
  transactionId String?
  createdAt     DateTime @default(now())
}

model Settings {
  id             String @id @default("default")
  storeName      String @default("AmanZone")
  slogan         String @default("Wholesale & B2B Construction Supply")
  logoUrl        String @default("")
  masterPasscode String @default("AmanZone2026") 
}
model Settings {
  id             String @id @default("default")
  storeName      String
  slogan         String
  logoUrl        String
  masterPasscode String
  heroHeading    String @default("YOUR RELIABLE SOURCE OF...")
}
